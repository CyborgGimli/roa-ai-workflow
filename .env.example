# Copy this file to .env and fill in your values.
# NEVER commit .env — it is gitignored.
# NEVER put real credentials in this file.

# Jira integration (get from id.atlassian.com → Security → API tokens)
JIRA_HOST=https://your-org.atlassian.net
JIRA_EMAIL=your-email@example.com
JIRA_API_TOKEN=<your-jira-api-token>

# GitHub Personal Access Token (get from github.com/settings/tokens)
# Required scopes: repo, read:packages
GITHUB_PERSONAL_ACCESS_TOKEN=<your-github-pat>

# Anthropic API key (get from console.anthropic.com/settings/keys)
ANTHROPIC_API_KEY=<your-anthropic-api-key>

# GitHub Packages credentials (for Maven — same PAT or a dedicated one)
GH_PACKAGES_USER=<your-github-username>
GH_PACKAGES_PAT=<your-github-pat>
